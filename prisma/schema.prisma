// Prisma schema — Phase 5.2: Core Portfolio content model.
//
// Scope is deliberately narrow: only the entities needed to represent the
// public portfolio's existing content (today's `src/features/portfolio/*/data.ts`
// static arrays) as real rows. Everything else `docs/architecture/domain-model.md`
// describes — Users/Roles/Permissions, Media, Blog, Analytics, AI/Embeddings,
// Audit/Version history, Draft/Publish workflow — belongs to a later phase and
// is intentionally absent here. See `docs/infrastructure/phase-5-2-implementation-notes.md`
// for exactly where this schema folds an architecture-doc entity (Category,
// ProjectMetric, ProjectLink, Media, Issuer) into a scalar/array/JSON field on
// one of the entities below, and why.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────

/// Shared accent-color token — mirrors `AccentColor` in `src/shared/types/common.ts`.
/// One enum reused by every entity that needs a themed accent, so the palette
/// (`docs/architecture` and `src/constants/theme.ts` both already limit this to
/// five colors) can't drift out of sync between the DB and the frontend.
enum AccentColor {
  PURPLE
  EMERALD
  CYAN
  AMBER
  PINK
}

/// Mirrors `SkillGroupIcon` in `src/features/portfolio/skills/types.ts`.
enum SkillIcon {
  CODE2
  BRAIN
  LAYOUT
  WRENCH
  CLOUD
}

/// Mirrors `EducationType` in `src/features/portfolio/education/types.ts`.
enum EducationType {
  SCHOOL
  COLLEGE
}

/// Mirrors `ContactMethodIcon` in `src/features/portfolio/contact/types.ts`.
enum SocialLinkIcon {
  GITHUB
  LINKEDIN
  EMAIL
  LOCATION
}

/// Mirrors `JourneyIcon` in `src/features/portfolio/journey/types.ts`.
enum JourneyIcon {
  GRADUATION_CAP
  BRAIN
  WORKFLOW
  BUILDING2
  GLOBE
  ZAP
  IMAGE
  TARGET
  SPARKLES
  AWARD
  CODE2
  TERMINAL_SQUARE
}

/// Where a `Media` row was stored — Cloudinary for uploads, LOCAL reserved
/// for legacy seeded paths not yet migrated into the media library.
enum MediaProvider {
  CLOUDINARY
  LOCAL
}

/// Asset kind — extensible for resume PDFs and future video demos.
enum MediaType {
  IMAGE
  VIDEO
  PDF
}

// ─────────────────────────────────────────────────────────────────────────
// Configuration content — singletons
//
// Hero, About, Resume, and ContactInformation each represent exactly one
// section's editable copy, not a list of records. Like `SiteSettings` /
// `HeroContent` in `domain-model.md §12`, "exactly one row" is enforced at
// the application layer (a `findFirst`, never a `findMany`, in each
// feature's future `data.ts`), not a DB constraint — the same reasoning
// `database-design.md §7` gives for `ResumeVersion.isActive`.
// ─────────────────────────────────────────────────────────────────────────

/// Singleton — the Hero section's editable copy. Mirrors `HeroData` in
/// `src/features/portfolio/hero/types.ts`.
model Hero {
  id String @id @default(cuid())

  eyebrow     String
  title       String
  subtitle    String
  description String @db.Text

  /// Public URL/path to the profile image. A direct `Media` foreign key is
  /// the eventual replacement (`domain-model.md §12`) — deferred until the
  /// Media Library phase actually exists; a bare URL is exactly what
  /// `HeroData.profileImage` already is today.
  profileImage String

  /// `InterestCard[]` (icon, label, title, subtitle, items[], accent) —
  /// stored as JSON rather than its own table. These cards are edited as a
  /// unit with Hero's other copy, never queried independently of it, and
  /// none of their fields need a foreign key or a WHERE clause of their own
  /// — the three properties that would justify a separate table.
  interestCards Json

  /// `HeroCta[]` (label, href, variant, icon, download?) — same reasoning
  /// as `interestCards`.
  ctas Json

  /// When false, the public hero omits the interest-card row entirely.
  showInterestCards Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Singleton — the About section's editable copy. Mirrors `AboutData` in
/// `src/features/portfolio/about/types.ts`.
model About {
  id String @id @default(cuid())

  label    String
  title    String
  subtitle String

  /// Paragraphs, in display order. A native string array, not JSON —
  /// every element is the same shape (plain text), which is exactly what
  /// Postgres array columns are for.
  story String[]

  currentlyLearningTitle String
  currentlyLearningItems String[]

  interestsLabel String
  interests      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Singleton — today's `SITE.resumePath` made data-driven. Mirrors
/// `ResumeData` in `src/features/portfolio/resume/types.ts`. Deliberately
/// **not** `ResumeVersion` (`domain-model.md §7`) — no version history in
/// this phase, so there's exactly one row, replaced in place on update,
/// with no `isActive` flag needed until a second row can ever exist.
model Resume {
  id String @id @default(cuid())

  label String
  title String

  /// Public path to the resume PDF.
  filePath String

  previewImage       String
  previewAlt         String
  previewImageWidth  Int
  previewImageHeight Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Singleton — the Contact section's editable copy. Mirrors `ContactInfo`
/// in `src/features/portfolio/contact/types.ts`. `domain-model.md §8` names
/// the equivalent entity `ContactChannel`; this phase's brief calls for
/// `ContactInformation` + `SocialLink` instead, which maps onto the same
/// shape one level deeper (one settings row, many channel rows).
model ContactInformation {
  id String @id @default(cuid())

  label       String
  title       String
  description String @db.Text

  sayHelloLabel String
  sayHelloHref  String

  socialLinks SocialLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// One channel card (GitHub / LinkedIn / Email / Location). Mirrors
/// `ContactMethod`. Always belongs to the one `ContactInformation` row —
/// modeled as a real child table (not JSON on the parent) because each row
/// needs its own stable identity for future admin drag-to-reorder, and
/// because `icon` is meaningfully constrained to a fixed enum.
model SocialLink {
  id String @id @default(cuid())

  contactInformationId String
  contactInformation    ContactInformation @relation(fields: [contactInformationId], references: [id], onDelete: Cascade)

  label String
  value String
  href  String
  icon  SocialLinkIcon

  /// Orderable pattern (`database-design.md §2.5`) — display order among
  /// this contact's channel cards.
  order Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// One channel per icon type per contact record — matches today's data,
  /// where `methods` has exactly one GitHub/LinkedIn/Email/Location entry.
  @@unique([contactInformationId, icon])
  @@index([contactInformationId, order])
}

// ─────────────────────────────────────────────────────────────────────────
// Portfolio content — Technology (shared) + Project
// ─────────────────────────────────────────────────────────────────────────

/// The single source of truth for a tool/language/framework — shared by
/// `Project` (via `ProjectTechnology`) and `SkillCategory` (via `Skill`).
/// See `domain-model.md §4.1`: today's static data has this concept
/// duplicated across `Project.techStack: string[]` and
/// `SkillItem { name, logo }`; this table is the 3NF fix for both at once.
model Technology {
  id String @id @default(cuid())

  name String @unique
  slug String @unique

  /// Simple Icons slug used to build the CDN logo URL — mirrors
  /// `getTechLogoSlug`/`getSimpleIconUrl` in `src/constants/tech-logos.ts`.
  logoSlug   String?
  websiteUrl String?

  projects ProjectTechnology[]
  skills   Skill[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A showcased project. Mirrors `Project` in
/// `src/features/portfolio/projects/types.ts`, with two normalizations
/// applied per `database-design.md §1`:
///   - `techStack: string[]` → a real `N─M` relation to `Technology`.
///   - `caseStudy` dropped entirely — it was always exactly `/projects/${slug}`
///     in every existing row, i.e. 100% derivable from `slug`. Storing a
///     value that can never legitimately disagree with another column is
///     the textbook case for *not* persisting it; the app computes the URL
///     from `slug` instead.
model Project {
  id String @id @default(cuid())

  slug          String  @unique
  featured      Boolean @default(false)
  isPlaceholder Boolean @default(false)
  /// Soft-hide from the public portfolio without deleting CMS data.
  isVisible     Boolean @default(true)

  name        String
  /// Free-text descriptive category (e.g. "Computer Vision"). Kept as a
  /// plain column rather than a normalized `Category` table — see
  /// `docs/infrastructure/phase-5-2-implementation-notes.md`.
  category    String
  tagline     String
  description String  @db.Text

  github   String?
  liveDemo String?

  /// Optional secondary demo link (walkthrough video, etc.) — mirrors
  /// `Project.demo?: { label, href }`. Both null or both set; enforced at
  /// the application layer, the same way `database-design.md §7` treats
  /// `ResumeVersion.isActive` rather than a DB-level check constraint.
  demoLabel String?
  demoHref  String?

  screenshot        String
  /// Optional FK to a `Media` row when the thumbnail was uploaded via the
  /// media library. `screenshot` remains denormalized as the public URL/path
  /// so existing reads and seeded local assets keep working without joins.
  screenshotMediaId String?
  screenshotMedia   Media?  @relation("ProjectScreenshotMedia", fields: [screenshotMediaId], references: [id], onDelete: SetNull)

  architectureImage String?
  ragPipelineImage  String?

  /// `ProjectMetric[]` ({ label, value }) — JSON, not its own table. See
  /// the implementation notes for why `ProjectMetric`/`ProjectLink` fold
  /// into columns here instead of becoming tables in this phase.
  metrics Json?

  overview String  @db.Text
  problem  String  @db.Text

  architecture       String[]
  implementation     String[]
  challenges         String[]
  lessonsLearned     String[]
  futureImprovements String[]

  /// `ProjectGalleryItem[]` ({ src, caption }) — JSON; see `metrics` above
  /// for the same reasoning.
  gallery Json?

  /// Optional hero eyebrow override. When empty, the public case study uses `category`.
  heroEyebrow String?

  /// Editable section headings — defaults preserve the existing public copy.
  overviewTitle            String @default("Overview")
  problemTitle             String @default("Problem")
  techStackTitle           String @default("Tech Stack")
  architectureTitle        String @default("Architecture")
  implementationTitle      String @default("Implementation")
  challengesTitle          String @default("Challenges")
  lessonsLearnedTitle      String @default("Lessons learned")
  futureImprovementsTitle  String @default("Future improvements")
  galleryTitle             String @default("Screenshots")
  videoTitle               String @default("Demo video")
  liveDemoTitle            String @default("Live demo")

  /// Per-section visibility. Defaults `true` so existing seeded projects keep rendering.
  showOverview             Boolean @default(true)
  showProblem              Boolean @default(true)
  showTechStack            Boolean @default(true)
  showArchitecture         Boolean @default(true)
  showImplementation       Boolean @default(true)
  showChallenges           Boolean @default(true)
  showLessonsLearned       Boolean @default(true)
  showFutureImprovements   Boolean @default(true)
  showGallery              Boolean @default(true)
  showVideo                Boolean @default(true)
  showLiveDemo             Boolean @default(true)
  showMetrics              Boolean @default(true)
  showArchitectureImage    Boolean @default(true)
  showRagPipelineImage     Boolean @default(true)

  technologies ProjectTechnology[]

  /// Orderable pattern — curated display order in the Projects grid.
  /// Not in `domain-model.md`'s attribute list for `Project`, added here
  /// because today's array order in `data.ts` *is* the current display
  /// order and that's genuinely primary data, not derivable from anything
  /// else (`database-design.md §1.2`'s reasoning for `pinnedOrder`).
  order Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([featured])
  @@index([isVisible])
  @@index([order])
  @@index([screenshotMediaId])
}

// ─────────────────────────────────────────────────────────────────────────
// Media — reusable asset infrastructure (Phase 9)
// ─────────────────────────────────────────────────────────────────────────

/// Canonical record for an uploaded file. Mirrors `domain-model.md §5`.
model Media {
  id String @id @default(cuid())

  /// Cloudinary `public_id` — null for legacy/local-only rows.
  publicId  String?
  url       String
  secureUrl String?
  provider  MediaProvider @default(CLOUDINARY)
  type      MediaType     @default(IMAGE)

  /// Environment-prefixed folder path, e.g. `dev/projects`.
  folder String

  width   Int?
  height  Int?
  format  String?
  bytes   Int?
  altText String?

  /// Clerk owner email until a `User` table exists.
  uploadedByEmail String?

  deletedAt DateTime?

  projectScreenshots Project[]         @relation("ProjectScreenshotMedia")
  blogFeaturedImages BlogPost[]        @relation("BlogFeaturedImage")
  siteOgImages       SiteSettings[]    @relation("SiteOgImage")
  attachments        MediaAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([folder, deletedAt])
  @@index([deletedAt])
  @@index([provider])
}

/// Polymorphic join for one-to-many media slots (galleries, inline images).
/// Singleton slots (project thumbnail, certificate image) use direct FKs instead.
model MediaAttachment {
  id String @id @default(cuid())

  mediaId String
  media   Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  attachableType String
  attachableId   String
  role           String
  /// Optional display caption — distinct from `Media.altText` (accessibility).
  caption        String?
  order          Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([attachableType, attachableId, role, order])
  @@unique([mediaId, attachableType, attachableId, role])
}

/// Join: which Technologies a Project uses, in display order. Mirrors
/// `ProjectTechnology` in `domain-model.md §4` exactly.
model ProjectTechnology {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  technologyId String
  technology   Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  /// Orderable pattern — tech-badge display order on the project card/page.
  order Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// A project can't list the same technology twice.
  @@unique([projectId, technologyId])
  @@index([projectId, order])
}

// ─────────────────────────────────────────────────────────────────────────
// Portfolio content — Skills
// ─────────────────────────────────────────────────────────────────────────

/// A skills-section grouping (Programming, AI/ML, Frameworks…). Mirrors
/// `SkillGroup` in `src/features/portfolio/skills/types.ts`.
model SkillCategory {
  id String @id @default(cuid())

  title  String @unique
  icon   SkillIcon
  accent AccentColor
  note   String

  /// Soft-hide this skill group from the public Skills section.
  isVisible Boolean @default(true)

  skills Skill[]

  /// Orderable pattern — display order among skill groups.
  order Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@index([isVisible])
}

/// Join: which Technologies belong to a SkillCategory, in display order.
/// Mirrors `SkillEntry` in `domain-model.md §4` (renamed `Skill` per this
/// phase's brief) — the concrete fix for `SkillItem { name, logo }`
/// duplicating what `Technology` already models once.
model Skill {
  id String @id @default(cuid())

  skillCategoryId String
  skillCategory   SkillCategory @relation(fields: [skillCategoryId], references: [id], onDelete: Cascade)

  technologyId String
  technology   Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  /// Orderable pattern — badge display order within its category.
  order Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// A category can't list the same technology twice.
  @@unique([skillCategoryId, technologyId])
  @@index([skillCategoryId, order])
}

// ─────────────────────────────────────────────────────────────────────────
// Portfolio content — Education & Certifications
// ─────────────────────────────────────────────────────────────────────────

/// An academic entry (school/college). Mirrors `EducationEntry` in
/// `src/features/portfolio/education/types.ts`.
model Education {
  id   String        @id @default(cuid())
  type EducationType

  institution String
  shortName   String?
  degree      String

  /// Display string (e.g. "2022 – 2026"), not two `DateTime` columns —
  /// matches today's data exactly; nothing in the UI parses this as a real
  /// date range today, so introducing structured dates isn't justified by
  /// any current requirement.
  period String

  location    String
  description String  @db.Text
  highlights  String[]

  expectedGraduation String?
  currentSemester    String?

  /// Soft-hide from the public Education section.
  isVisible Boolean @default(true)

  /// Orderable pattern — timeline display order.
  order Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([order])
  @@index([isVisible])
}

/// A completed certification. Mirrors `Certification` in
/// `src/features/portfolio/certifications/types.ts`. `domain-model.md §4`
/// extracts the issuer into its own `Issuer` entity for 3NF; that table
/// isn't in this phase's allowed entity list, so `provider`/`providerLogo`
/// stay scalar columns here — see the implementation notes.
model Certification {
  id String @id @default(cuid())

  name         String
  provider     String
  providerLogo String?

  /// Display string ("Aug 2024") — some existing rows use the literal
  /// placeholder "—" for "not applicable", which a `DateTime` column
  /// can't represent without inventing a sentinel value. Kept as the
  /// nullable display string the current data already uses.
  completionDate String?

  credentialUrl String
  verifyUrl     String
  image         String

  /// Soft-hide from the public Certifications section.
  isVisible Boolean @default(true)

  /// Orderable pattern — grid display order.
  order Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@index([isVisible])
}

// ─────────────────────────────────────────────────────────────────────────
// Portfolio content — Journey
// ─────────────────────────────────────────────────────────────────────────

/// A "Learning Journey" timeline entry. Mirrors `JourneyStep` in
/// `src/features/portfolio/journey/types.ts`. Not part of Phase 5.2's
/// original 12-entity list — added here in Phase 5.3 because the migration
/// order that phase's brief specifies (Hero → About → Projects → Skills →
/// **Journey** → Education → …) requires it, and `domain-model.md §4`
/// already fully specifies the equivalent `JourneyMilestone` entity
/// (`label`, `year`, `description`, `icon`, `accentColor`, `isCurrent`,
/// `subItems[]`, `order`, Orderable pattern) — this model is a direct,
/// literal transcription of that existing design, not a new one. See
/// `docs/infrastructure/phase-5-3-implementation-notes.md`.
model JourneyMilestone {
  id String @id @default(cuid())

  label       String
  /// Display string ("2024", "2025–2026", "Now") — same reasoning as
  /// `Education.period`: nothing parses this as a real date today.
  year        String
  description String      @db.Text
  icon        JourneyIcon
  accent      AccentColor

  /// Only the "Currently Learning" milestone sets this — renders the
  /// timeline node in its active/current state.
  isCurrent Boolean  @default(false)
  subItems  String[]

  /// Soft-hide from the public Journey timeline.
  isVisible Boolean @default(true)

  /// Orderable pattern — chronological timeline display order (not always
  /// the same as sorting by `year`, since several milestones share a year).
  order Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@index([isVisible])
}

// ─────────────────────────────────────────────────────────────────────────
// Admin platform — Blog, Messages, AI config, Site settings (Phase 12)
// ─────────────────────────────────────────────────────────────────────────

enum BlogPostStatus {
  DRAFT
  PUBLISHED
}

enum ContactMessageStatus {
  UNREAD
  READ
  ARCHIVED
}

/// Blog post — mirrors the Projects CMS collection pattern.
model BlogPost {
  id String @id @default(cuid())

  slug    String         @unique
  title   String
  excerpt String         @db.Text
  content String         @db.Text
  status  BlogPostStatus @default(DRAFT)
  /// Soft-hide a published post from public routes without unpublishing.
  isVisible Boolean @default(true)
  tags    String[]

  featuredImage        String
  featuredImageMediaId String?
  featuredImageMedia   Media?  @relation("BlogFeaturedImage", fields: [featuredImageMediaId], references: [id], onDelete: SetNull)

  metaTitle       String?
  metaDescription String? @db.Text

  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([isVisible])
  @@index([publishedAt])
  @@index([featuredImageMediaId])
}

/// Inbound contact form submission — admin inbox only (no Resend changes).
model ContactMessage {
  id String @id @default(cuid())

  name    String
  email   String
  subject String
  body    String               @db.Text
  status  ContactMessageStatus @default(UNREAD)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

/// Singleton — AI assistant configuration (chatbot not implemented).
model AiConfiguration {
  id String @id @default(cuid())

  provider            String @default("openai")
  chatModel           String @default("gpt-4o-mini")
  embeddingModel      String @default("text-embedding-3-small")
  temperature         Float  @default(0.7)
  maxTokens           Int    @default(1024)
  embeddingDimensions Int    @default(1536)

  systemPrompt  String @db.Text
  chatbotPrompt String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Singleton — global site settings editable from admin.
model SiteSettings {
  id String @id @default(cuid())

  siteTitle       String
  siteDescription String   @db.Text
  keywords        String[]

  ogImage        String
  ogImageMediaId String?
  ogImageMedia   Media?  @relation("SiteOgImage", fields: [ogImageMediaId], references: [id], onDelete: SetNull)
  favicon        String

  github          String
  linkedin        String
  githubDisplay   String
  linkedinDisplay String

  maintenanceMode    Boolean @default(false)
  maintenanceMessage String? @db.Text

  /// Public portfolio section visibility — soft-hide only; CMS data is preserved.
  showHero         Boolean @default(true)
  showAbout        Boolean @default(true)
  showJourney      Boolean @default(true)
  showSkills       Boolean @default(true)
  showProjects     Boolean @default(true)
  showEducation    Boolean @default(true)
  showCertificates Boolean @default(true)
  showResume       Boolean @default(true)
  showBlog         Boolean @default(true)
  showContact      Boolean @default(true)
  showContactForm  Boolean @default(true)
  showInterests    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ogImageMediaId])
}
