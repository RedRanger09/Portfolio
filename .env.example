# Copy this file to `.env.local` and fill in only what you're actively using.
# Every var here is read through `src/config/env.ts` — never `process.env` directly.

# Public site URL — canonical links, OG metadata, sitemap generation.
NEXT_PUBLIC_APP_URL=https://akshaytiwari.dev

# ── PostgreSQL + Prisma (Neon) ──
# Two connection strings, both from your Neon project's "Connect" dialog:
#   DATABASE_URL — the POOLED connection string (host ends in "-pooler").
#     Used by the running app (`lib/prisma.ts`) — Vercel's serverless
#     functions need pooling to avoid exhausting Postgres' connection limit.
#   DIRECT_URL   — the UNPOOLED connection string (no "-pooler" in the host).
#     Used only by `prisma migrate`/`prisma db pull` once the schema has
#     models — migrations don't work reliably through a transaction-mode
#     pooler. Not read by the app at runtime.
# See docs/infrastructure/database-and-storage.md §1.2.
DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@ep-example.region.aws.neon.tech/dbname?sslmode=require

# ── Future: Clerk authentication (Admin Dashboard) ──
# CLERK_SECRET_KEY=
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

