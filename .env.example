# Public site — set to your production domain on Vercel (e.g. https://akshaytiwari.dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Neon PostgreSQL (pooled + direct)
# Production: use Neon's pooled URL for DATABASE_URL and the direct URL for DIRECT_URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Clerk authentication (Admin Dashboard)
# Use separate Clerk applications per environment (dev / preview / production).
# Production recommendation: disable public sign-up (invite-only / owner account only).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin

# Owner email allowed to access /admin and mutation Server Actions
ADMIN_EMAIL=you@example.com

# Cloudinary — media uploads (server-side only; secrets stay off the client)
# Required on Vercel Production for admin media uploads.
# SVG uploads are rejected by the app; use JPEG/PNG/WebP/GIF only.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend — optional contact-form email notifications (server-only).
# If unset, messages still save to the Admin → Messages inbox.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=

# @future OpenAI
# OPENAI_API_KEY=

# Google Analytics 4
# Measurement ID (G-XXXXXXXX) — public site page-view tracking (safe to expose via server→client prop).
# GOOGLE_ANALYTICS_ID=G-XXXXXXXX
#
# Admin dashboard reporting (server-only — never NEXT_PUBLIC_*):
# 1. Create a Google Cloud service account with no user roles required on the project itself.
# 2. Enable the Google Analytics Data API on that GCP project.
# 3. Download a JSON key; copy client_email and private_key below.
# 4. In GA4 Admin → Property access management, add the service account email as Viewer.
# 5. Property ID is the numeric ID under Admin → Property settings (not the G- measurement ID).
# GA4_PROPERTY_ID=123456789
# GOOGLE_SERVICE_ACCOUNT_EMAIL=analytics-reader@your-project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Vercel Production notes ---
# Build Command: npm run vercel-build
#   (runs `prisma migrate deploy` then `next build`)
# CI / local build uses: npm run build  (generate + next build, no migrate)
